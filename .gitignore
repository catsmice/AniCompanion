# Xcode
# The .xcodeproj is generated by XcodeGen from project.yml (the source of truth).
# Run `xcodegen generate` after cloning; the generated project is not committed.
*.xcodeproj/
*.xcworkspace/xcuserdata/
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
build/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
Packages/
Package.pins
# No SPM packages currently — Package.resolved carries nothing to pin, so it's ignored.
Package.resolved

# CocoaPods
Pods/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# VRM model files (large binaries, download separately) — except the bundled default, which is
# redistributable (VRoid AvatarSample_A, CC-permissive; see ATTRIBUTION.md). Alicia and any other
# local models stay ignored (Alicia's license forbids redistribution).
AniCompanion/Resources/VRMModel/*.vrm
!AniCompanion/Resources/VRMModel/AvatarSample_A.vrm

# API keys
*.env
.env.*
# …but keep the committed example (placeholder values only)
!examples/hermes.env

# Python
__pycache__/
*.pyc

# IDE
.idea/
*.swp
*~

# Research / working notes (not for the repo)
docs/notes/
scripts/dev-signing-identity

# Release build + DMG artifacts (scripts/build-dmg.sh)
.build-release/
AniCompanion-*.dmg
