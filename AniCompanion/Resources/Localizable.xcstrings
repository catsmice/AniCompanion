{
  "sourceLanguage" : "en",
  "strings" : {
    "Add your own VRM…" : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "加入你自己的 VRM…" } }
      }
    },
    "Character Model" : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "角色模型" } }
      }
    },
    "Couldn't import model: %@" : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法匯入模型：%@" } }
      }
    },
    "Download Alicia Solid" : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "下載 Alicia Solid" } }
      }
    },
    "Download failed — check your connection and try again." : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "下載失敗——請檢查網路連線後再試一次。" } }
      }
    },
    "Download failed: %@" : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "下載失敗：%@" } }
      }
    },
    "Downloading…" : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "下載中…" } }
      }
    },
    "Imported models are stored in Application Support. Alicia Solid (© DWANGO) is fetched for your own use only." : {
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "匯入的模型會儲存在 Application Support 資料夾。Alicia Solid（© DWANGO）僅供你個人使用而下載。" } }
      }
    },
    "Paused while live captions are on — so she doesn't listen to what you're watching." : {
      "comment" : "Settings: hands-free disabled note while live captions run",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即時字幕開啟時已暫停——這樣她就不會聆聽你正在觀看的內容。" } }
      }
    },
    "Hands-free voice mode pauses while live captions run, so she doesn't listen to and reply to what you're watching." : {
      "comment" : "Settings: live transcription vs hands-free note",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即時字幕執行時，免持語音模式會暫停，這樣她就不會聆聽並回應你正在看的內容。" } }
      }
    },
    "Translation engine" : {
      "comment" : "Settings: caption translation engine picker",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "翻譯引擎" } }
      }
    },
    "Apple Translation (on-device)" : {
      "comment" : "Settings: translation engine option",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "Apple 翻譯（裝置端）" } }
      }
    },
    "Agent backend (LLM)" : {
      "comment" : "Settings: translation engine option",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "Agent 後端（LLM）" } }
      }
    },
    "Translates through your configured agent backend — context-aware and usually more accurate, but adds latency (and cost if the backend is a paid cloud model). The transcript is sent to that backend." : {
      "comment" : "Settings: LLM translation engine hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "透過你設定的 agent 後端翻譯——能理解前後文、通常更準確，但延遲較高（若後端是付費雲端模型也會產生費用）。逐字稿會傳送到該後端。" } }
      }
    },
    "Translate captions" : {
      "comment" : "Settings: live transcription translate toggle",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "翻譯字幕" } }
      }
    },
    "Each finished sentence is translated on-device and shown as the caption, with the original in a smaller line." : {
      "comment" : "Settings: translate hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "每句完成後會在裝置上翻譯並顯示為字幕，原文以較小字顯示。" } }
      }
    },
    "Translate to" : {
      "comment" : "Settings: translation target language",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "翻譯成" } }
      }
    },
    "Translation pack installed — translates on-device." : {
      "comment" : "Settings: translation pack status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已安裝翻譯語言包——在裝置上翻譯。" } }
      }
    },
    "Translation pack not downloaded — add it in System Settings → General → Language & Region → Translation Languages." : {
      "comment" : "Settings: translation pack status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "尚未下載翻譯語言包——請在「系統設定 → 一般 → 語言與地區 → 翻譯語言」加入。" } }
      }
    },
    "This language pair can't be translated on-device on this Mac — captions will stay untranslated." : {
      "comment" : "Settings: translation pack status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "這台 Mac 無法在裝置上翻譯此語言組合——字幕將維持原文。" } }
      }
    },
    "Checking translation availability…" : {
      "comment" : "Settings: translation pack status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在檢查翻譯可用性…" } }
      }
    },
    "Starting live captions…" : {
      "comment" : "Live captions: overlay while session starts",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在啟動即時字幕…" } }
      }
    },
    "Live captions are running." : {
      "comment" : "Settings: live transcription session status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即時字幕執行中。" } }
      }
    },
    "No display found to capture audio from." : {
      "comment" : "Live captions: SCK error",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "找不到可擷取音訊的顯示器。" } }
      }
    },
    "System audio capture failed: %@" : {
      "comment" : "Live captions: SCK error",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "系統音訊擷取失敗：%@" } }
      }
    },
    "Live transcription doesn't support %@ on this Mac." : {
      "comment" : "Live captions: engine error",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "這台 Mac 的即時轉錄不支援 %@。" } }
      }
    },
    "The speech recognizer is unavailable right now." : {
      "comment" : "Live captions: engine error",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "語音辨識器目前無法使用。" } }
      }
    },
    "Listening to your Mac's audio" : {
      "comment" : "Live captions: overlay indicator",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在聆聽 Mac 播放的聲音" } }
      }
    },
    "Downloading speech model… %lld%%" : {
      "comment" : "Live captions: overlay while model downloads",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在下載語音模型… %lld%%" } }
      }
    },
    "Live Transcription" : {
      "comment" : "Settings: live transcription section title",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即時轉錄" } }
      }
    },
    "Live captions of your Mac's audio" : {
      "comment" : "Settings: live transcription toggle",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "為 Mac 播放的聲音顯示即時字幕" } }
      }
    },
    "Off by default. When on, 小光 listens to the audio playing on your Mac (a video, a meeting) and shows live captions — in her speech bubble in pet mode, or under the character here. Display-only; nothing is spoken." : {
      "comment" : "Settings: live transcription hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "預設關閉。開啟後，小光會聆聽 Mac 正在播放的聲音（影片、會議），並顯示即時字幕——桌寵模式顯示在她的對話泡泡，一般模式顯示在角色下方。僅顯示文字，不會朗讀。" } }
      }
    },
    "Source language" : {
      "comment" : "Settings: live transcription source language",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "來源語言" } }
      }
    },
    "Listen to your Mac's audio?" : {
      "comment" : "Settings: live transcription consent alert title",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "要聆聽 Mac 播放的聲音嗎？" } }
      }
    },
    "When enabled, AniCompanion captures the audio playing on your Mac (videos, music, calls) and transcribes it into live captions. With an on-device model, audio never leaves your Mac; on older systems some languages use Apple's speech servers. macOS will ask for Screen Recording permission (that's how system audio capture is authorized). You can turn this off anytime." : {
      "comment" : "Settings: live transcription consent alert message",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "開啟後，AniCompanion 會擷取 Mac 正在播放的聲音（影片、音樂、通話）並轉錄成即時字幕。使用裝置端模型時，音訊完全不會離開你的 Mac；在較舊的系統上，部分語言會使用 Apple 的語音伺服器。macOS 會要求「螢幕錄製」權限（系統音訊擷取即透過此權限授權）。你隨時可以關閉。" } }
      }
    },
    "On-device model installed — audio never leaves your Mac." : {
      "comment" : "Settings: live transcription model status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已安裝裝置端模型——音訊完全不會離開你的 Mac。" } }
      }
    },
    "On-device model downloads automatically on first use (one-time, free)." : {
      "comment" : "Settings: live transcription model status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "首次使用時會自動下載裝置端模型（一次性、免費）。" } }
      }
    },
    "No on-device model for this language on this macOS — audio is transcribed by Apple's servers." : {
      "comment" : "Settings: live transcription model status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "這個 macOS 沒有此語言的裝置端模型——音訊會交由 Apple 伺服器轉錄。" } }
      }
    },
    "This language isn't supported on this Mac." : {
      "comment" : "Settings: live transcription model status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "這台 Mac 不支援此語言。" } }
      }
    },
    "Checking model availability…" : {
      "comment" : "Settings: live transcription model status",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在檢查模型可用性…" } }
      }
    },
    "Voice interruption is on — just talk to interrupt her" : {
      "comment" : "Mic button tooltip when full-duplex is on",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已開啟語音打斷——直接說話即可打斷她" } }
      }
    },
    "Rate" : {
      "comment" : "Settings: Apple TTS speech rate",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "語速" } }
      }
    },
    "Auto (best installed)" : {
      "comment" : "Settings: Apple TTS auto voice option",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "自動（已安裝的最佳語音）" } }
      }
    },
    "Runs fully on-device — no key, no network. For natural-sounding voices, download an Enhanced or Premium voice in System Settings → Accessibility → Spoken Content → Manage Voices." : {
      "comment" : "Settings: Apple TTS hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "完全在裝置上執行——不需金鑰、不需網路。若想要更自然的語音，可在「系統設定 → 輔助使用 → 朗讀內容 → 管理語音」下載更高品質的語音。" } }
      }
    },
    "Hands-free mode" : {
      "comment" : "Settings: hands-free voice toggle",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "免持模式" } }
      }
    },
    "Keep listening and reply automatically — just talk, no need to click the mic each time." : {
      "comment" : "Settings: hands-free mode hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "持續聆聽並自動回覆——直接說話即可，不必每次點擊麥克風。" } }
      }
    },
    "Let me interrupt her by voice" : {
      "comment" : "Settings: full-duplex barge-in toggle",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "允許用語音打斷她" } }
      }
    },
    "Full-duplex: talk over her to interrupt. While she's speaking, other apps' audio is briefly quieted (needed for echo cancellation). Off: take turns and interrupt with the mic button." : {
      "comment" : "Settings: full-duplex mode hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "全雙工：可直接說話打斷她。當她說話時，其他 App 的聲音會暫時降低（用於回音消除）。關閉時：輪流對話，並用麥克風按鈕打斷。" } }
      }
    },
    "Glance interval" : {
      "comment" : "Settings: screen vision proactive-glance interval",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "查看間隔" } }
      }
    },
    "%lld min" : {
      "comment" : "Settings: minutes option for glance interval",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "%lld 分鐘" } }
      }
    },
    "How often she glances at your screen while you're heads-down. A screenshot is sent to your model each glance — she only comments when there's something worth mentioning." : {
      "comment" : "Settings: glance interval hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "當你專心工作時，她多久看一次你的螢幕。每次查看都會傳送一張螢幕截圖到你的模型——只有在有值得一提的事情時她才會開口。" } }
      }
    },
    "Screen Vision" : {
      "comment" : "Settings section: screen vision",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "螢幕視覺" } }
      }
    },
    "Let her see your screen" : {
      "comment" : "Settings: screen vision toggle",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "讓她看見你的螢幕" } }
      }
    },
    "Let her see your screen?" : {
      "comment" : "Settings: screen vision consent alert title",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "要讓她看見你的螢幕嗎？" } }
      }
    },
    "Off by default. When on, 小光 glances at what you're working on when she speaks — screen images are sent to your configured AI model, which may be a cloud provider." : {
      "comment" : "Settings: screen vision description",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "預設為關閉。開啟後，小光會在說話時看一眼你正在做的事——螢幕影像會傳送到你設定的 AI 模型，該模型可能位於雲端。" } }
      }
    },
    "When enabled, AniCompanion captures your focused window (or the whole screen) and sends the image to your configured AI model so 小光 can understand what you're working on. If your model runs in the cloud, the screenshot leaves your Mac. macOS will also ask for Screen Recording permission. You can turn this off anytime." : {
      "comment" : "Settings: screen vision consent alert body",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "開啟後，AniCompanion 會擷取你的焦點視窗（或整個螢幕），並將影像傳送到你設定的 AI 模型，讓小光能理解你正在做的事。如果你的模型在雲端執行，螢幕截圖就會離開你的 Mac。macOS 也會要求「螢幕錄製」權限。你可以隨時關閉此功能。" } }
      }
    },
    "Capture" : {
      "comment" : "Settings: screen vision capture-scope picker label",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "擷取範圍" } }
      }
    },
    "Screen Recording permission needed (may require a relaunch after granting)." : {
      "comment" : "Settings: screen vision permission-needed row",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "需要「螢幕錄製」權限（授權後可能需要重新啟動 App）。" } }
      }
    },
    "Grant…" : {
      "comment" : "Settings: button to request Screen Recording permission",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "授權…" } }
      }
    },
    "Capturing…" : {
      "comment" : "Settings: screen-capture test button, in progress",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "擷取中…" } }
      }
    },
    "Test: capture now" : {
      "comment" : "Settings: screen-capture test/preview button",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "測試：立即擷取" } }
      }
    },
    "Enable" : {
      "comment" : "Settings: consent alert confirm button",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "啟用" } }
      }
    },
    "Could not decode the captured image." : {
      "comment" : "Settings: screen capture preview decode error",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法解碼擷取的影像。" } }
      }
    },
    "Focused window" : {
      "comment" : "Settings: screen vision scope name",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "焦點視窗" } }
      }
    },
    "Entire screen" : {
      "comment" : "Settings: screen vision scope name",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "整個螢幕" } }
      }
    },
    "Only the window of the app you're working in — never AniCompanion, and not your other windows." : {
      "comment" : "Settings: focused-window scope hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "只擷取你正在使用的 App 視窗——絕不會擷取 AniCompanion，也不會擷取你的其他視窗。" } }
      }
    },
    "The whole screen (AniCompanion's own overlay is excluded)." : {
      "comment" : "Settings: entire-screen scope hint",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "整個螢幕（不包含 AniCompanion 自己的疊加視窗）。" } }
      }
    },
    "Screen Recording permission isn't granted. Enable it in System Settings → Privacy & Security → Screen Recording." : {
      "comment" : "ScreenVisionError: not authorized",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "尚未授予「螢幕錄製」權限。請至「系統設定」→「隱私權與安全性」→「螢幕錄製」開啟。" } }
      }
    },
    "Nothing to look at yet — open the app you're working in first." : {
      "comment" : "ScreenVisionError: no capture target",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "目前沒有可看的內容——請先開啟你正在使用的 App。" } }
      }
    },
    "Screen capture failed: %@" : {
      "comment" : "ScreenVisionError: capture failed with detail",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "螢幕擷取失敗：%@" } }
      }
    },
    "Agent backend" : {
      "comment" : "Settings: which AI agent gateway to talk to",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "Agent 後端" } }
      }
    },
    "AI Agent | Xiaoguang" : {
      "comment" : "Window title — character name",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "AI Agent | 小光" } }
      }
    },
    "Angry" : {
      "comment" : "Emotion name",
      "localizations" : {
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "生氣" } }
      }
    },
