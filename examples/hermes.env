# Example Hermes Agent settings for AniCompanion.
#
# These are the keys AniCompanion cares about — add them to your real Hermes env
# file at ~/.hermes/.env (Hermes has many other settings; see its own docs).
# DO NOT commit your real key.

# Enable the OpenAI-compatible HTTP API server that AniCompanion connects to.
API_SERVER_ENABLED=true

# Bearer token the app must send. Generate your own, e.g.:  openssl rand -hex 32
# Put this same value into the app's Settings → Connection → API Key.
API_SERVER_KEY=replace-with-openssl-rand-hex-32

# Optional: allow a browser origin to call the API (not needed for the macOS app).
# API_SERVER_CORS_ORIGINS=http://localhost:3000

# The gateway listens on http://127.0.0.1:8642 by default — that's what the app
# expects in Settings → Connection → Endpoint (with Agent backend = Hermes Agent).
#
# Your model provider (e.g. OpenRouter) and any MCP tool servers are configured
# elsewhere in Hermes' own config; see docs/hermes-setup.md.
